<Configuration>
  <Networking>Enable</Networking>
  <MemoryInMB>4096</MemoryInMB>
  <LogonCommand>
    <Command>powershell.exe -NoExit -ExecutionPolicy Bypass -Command "Write-Host '[ra-h] Testing install.ps1 (remote, main branch) in Windows Sandbox' -ForegroundColor Green; Set-Location $env:USERPROFILE; &amp; ([scriptblock]::Create((Invoke-RestMethod https://raw.githubusercontent.com/bradwmorris/ra-h_os/main/scripts/install.ps1))) -Yes"</Command>
  </LogonCommand>
</Configuration>
